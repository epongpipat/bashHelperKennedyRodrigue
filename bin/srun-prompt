#!/bin/bash

module load bashHelperKennedyRodrigue
source bashHelperKennedyRodrigueFunctions.sh

# partition --------------------------------------------------------------------
declare -a partitions
partitions[0]="dev"
partitions[1]="kenrod"
partitions[2]="normal"

echo -e "partitions:"
for i in "${!partitions[@]}"; do
    echo -e "\t${i}:\t${partitions[$i]}"
done
partition_k=$(get_valid_input -p "which partition do you want to run?" -o ${!partitions[@]})
partition="${partitions[$partition_k]}"
echo -e "partition:\t${partition}"

# nodelist ---------------------------------------------------------------------
declare -a nodelists_dev
nodelists_dev[0]="any"
nodelists_dev[5]="compute-05"

declare -a nodelists_kenrod
nodelists_kenrod[0]="any"
nodelists_kenrod[2]="compute-02"
nodelists_kenrod[16]="compute-16"

declare -a nodelists_normal
nodelists_normal[0]="any"
nodelists_normal[4]="compute-04"
nodelists_normal[7]="compute-07"
nodelists_normal[15]="compute-15"

declare -n nodelists="nodelists_${partition}"
echo -e "\nnodelists:"
for i in "${!nodelists[@]}"; do
    echo -e "\t${i}:\t${nodelists[$i]}"
done
nodelist_k=$(get_valid_input -p "which nodelists do you want to run? (default: 0)" -o ${!nodelists[@]} -d 0 -e 1)
nodelist="${nodelists[$nodelist_k]}"
echo -e "nodelist:\t${nodelist}"

# opts -------------------------------------------------------------------------
cmd="srun --partition=${partition}"
if [[ ${nodelist} != 'any' ]]; then
    cmd="${cmd} --nodelist=${nodelist}"
fi


declare -a opts
opts[0]="${cmd} --nodes=1 --ntasks=1 --cpus-per-task=1 --mem=4G --time=0-16:00:00 --pty /bin/bash"
opts[1]="${cmd} --nodes=1 --ntasks=1 --cpus-per-task=1 --mem=8G --time=0-16:00:00 --pty /bin/bash"
opts[2]="${cmd} --nodes=1 --ntasks=1 --cpus-per-task=3 --mem=16G --time=0-16:00:00 --pty /bin/bash"
opts[3]="${cmd} --nodes=1 --ntasks=1 --cpus-per-task=6 --mem=32G --time=0-16:00:00 --pty /bin/bash"
# opts[4]="srun --nodes=1 --ntasks=1 --cpus-per-task=12 --mem=64G --partition=${partition} --pty /bin/bash"

declare -a opts_desc
opts_desc[0]="[default]"
opts_desc[1]="[8GB mem]"
opts_desc[2]="[1/4*max]"
opts_desc[3]="[1/2*max]"
# opts_desc[4]="[max]\t"

echo -e "\noptions:"
for i in "${!opts[@]}"; do
    echo -e "\t${i}:\t${opts_desc[$i]}\t${opts[$i]}"
done

srun_k=$(get_valid_input -p "which srun command do you want to run? (hit enter to run default [0])" -o ${!opts[@]} -d 0 -e 1)
echo -e "\ncommand:\n${opts[$srun_k]}"
eval ${opts[$srun_k]}